{
    "interface_version": 2,
    "name": "MaaTOT",
    "label": "生煎包小助手",
    "icon": "logo.ico",
    "github": "https://github.com/Coxwtwo/MaaTOT",
    "welcome": "欢迎食用生煎包OvO！\n\n不要在任何平台的未定事件簿官方账号下面提到MaaTOT！",
    "contact": "./CONTACT.md",
    "controller": [
        {
            "name": "ADB",
            "label": "模拟器",
            "type": "Adb",
            "display_short_side": 720
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "./resource/base"
            ],
            "controller": [
                "ADB"
            ]
        },
        {
            "name": "B 服",
            "path": [
                "./resource/base",
                "./resource/bilibili"
            ],
            "controller": [
                "ADB"
            ]
        },
        {
            "name": "国际服（简体中文）",
            "path": [
                "./resource/base",
                "./resource/intl"
            ],
            "controller": [
                "ADB"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "-u",
            "./../agent/main.py"
        ]
    },
    "task": [],
    "option": {
        "复盘次数": {
            "type": "select",
            "cases": [
                {
                    "name": "1次",
                    "pipeline_override": {
                        "Flag_复盘确认弹窗": {
                            "next": [
                                "Click_复盘1次确定",
                                "Flag_复盘次数最小"
                            ]
                        }
                    }
                },
                {
                    "name": "2次",
                    "pipeline_override": {
                        "Flag_复盘确认弹窗": {
                            "next": [
                                "Click_复盘2次确定",
                                "Flag_复盘次数最小"
                            ]
                        }
                    }
                },
                {
                    "name": "3次",
                    "pipeline_override": {
                        "Flag_复盘确认弹窗": {
                            "next": [
                                "Click_复盘3次确定",
                                "Flag_复盘次数最小"
                            ]
                        }
                    }
                },
                {
                    "name": "4次",
                    "pipeline_override": {
                        "Flag_复盘确认弹窗": {
                            "next": [
                                "Click_复盘4次确定",
                                "Flag_复盘次数最小"
                            ]
                        }
                    }
                },
                {
                    "name": "5次",
                    "pipeline_override": {
                        "Flag_复盘确认弹窗": {
                            "next": [
                                "Click_复盘5次确定",
                                "Flag_复盘次数最小"
                            ]
                        }
                    }
                }
            ]
        },
        "使用能量饮料": {
            "type": "switch",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "Flag_体力不足弹窗": {
                            "enabled": false
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "Flag_体力不足弹窗": {
                            "enabled": true
                        }
                    }
                }
            ]
        },
        "能量饮料类型": {
            "type": "select",
            "cases": [
                {
                    "name": "30体力饮料",
                    "pipeline_override": {
                        "Click_能量饮料窗口": {
                            "next": [
                                "Click_30体力饮料"
                            ]
                        }
                    }
                },
                {
                    "name": "60体力饮料",
                    "pipeline_override": {
                        "Click_能量饮料窗口": {
                            "next": [
                                "Click_60体力饮料"
                            ]
                        }
                    }
                }
            ]
        },
        "开始前自动补足体力": {
            "type": "switch",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "体力检查": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "体力检查": {
                            "enabled": false
                        }
                    }
                }
            ]
        }
    },
    "import": [
        "resource/tasks/preset/Daily.json",
        "resource/tasks/T_startup.json",
        "resource/tasks/T_领取邮件.json",
        "resource/tasks/T_领取友谊徽章.json",
        "resource/tasks/T_领取基地奖励.json",
        "resource/tasks/T_好感度.json",
        "resource/tasks/T_逸梦.json",
        "resource/tasks/T_专属甜心.json",
        "resource/tasks/T_进修副本.json",
        "resource/tasks/T_异常副本.json",
        "resource/tasks/T_外勤委托.json",
        "resource/tasks/T_领取任务奖励.json",
        "resource/tasks/T_领取绮思奖励.json",
        "resource/tasks/T_试炼神殿.json",
        "resource/tasks/T_shutdown.json",
        "resource/tasks/T_购买免费礼包.json",
        "resource/tasks/T_提交材料活动.json",
        "resource/tasks/T_拼图活动.json",
        "resource/tasks/T_翻格活动.json"
    ]
}